    <graderinfo format="html"><text><![CDATA[<ul><li>ARP: IP→MAC, broadcast (0,5 b)</li><li>RARP: MAC→IP, nedostatečný (0,5 b)</li><li>Vývoj RARP→BOOTP→DHCP (0,5 b)</li><li>DHCP: co poskytuje, DORA, pronájem (0,5 b)</li></ul>]]></text></graderinfo>
    <responsetemplate format="html"><text></text></responsetemplate>
