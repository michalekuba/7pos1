  <question type="multichoice"><name><text>P11-02 Typy DNS serverů</text></name>
    <questiontext format="html"><text><![CDATA[<p>Jaké <strong>typy DNS serverů</strong> existují? (Vyberte všechny správné.)</p>]]></text></questiontext>
    <generalfeedback format="html"><text><![CDATA[<p>Primární (data vznikají, autoritativní, jeden). Sekundární (kopie, autoritativní, min. jeden). Pomocný/caching only (neautoritativní, cache).</p>]]></text></generalfeedback>
    <defaultgrade>1</defaultgrade><penalty>0.3333333</penalty><hidden>0</hidden><single>false</single><shuffleanswers>true</shuffleanswers><answernumbering>abc</answernumbering>
    <correctfeedback format="html"><text><![CDATA[<p>Správně!</p>]]></text></correctfeedback><partiallycorrectfeedback format="html"><text><![CDATA[<p>Částečně správně.</p>]]></text></partiallycorrectfeedback><incorrectfeedback format="html"><text><![CDATA[<p>Nesprávně.</p>]]></text></incorrectfeedback><shownumcorrect/>
    <answer fraction="33.33333" format="html"><text><![CDATA[<p>Primární – zde vznikají data, autoritativní, právě jeden pro doménu</p>]]></text><feedback format="html"><text><![CDATA[<p>Správně.</p>]]></text></feedback></answer>
    <answer fraction="33.33333" format="html"><text><![CDATA[<p>Sekundární – automatická kopie primárního, autoritativní, min. jeden</p>]]></text><feedback format="html"><text><![CDATA[<p>Správně.</p>]]></text></feedback></answer>
    <answer fraction="33.33333" format="html"><text><![CDATA[<p>Pomocný (caching only) – neautoritativní, uchovává předchozí odpovědi</p>]]></text><feedback format="html"><text><![CDATA[<p>Správně.</p>]]></text></feedback></answer>
    <answer fraction="-50" format="html"><text><![CDATA[<p>Distribuční – šíří data roztékáním (flooding)</p>]]></text><feedback format="html"><text><![CDATA[<p>Nesprávně.</p>]]></text></feedback></answer>
    <answer fraction="-50" format="html"><text><![CDATA[<p>Záložní – aktivuje se pouze při výpadku primárního</p>]]></text><feedback format="html"><text><![CDATA[<p>Nesprávně. Sekundární je aktivní vždy, nejen při výpadku.</p>]]></text></feedback></answer>
