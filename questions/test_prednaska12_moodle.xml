    <answer fraction="25" format="html"><text><![CDATA[<p>Binární přenos dat v rámcích</p>]]></text><feedback format="html"><text><![CDATA[<p>Správně.</p>]]></text></feedback></answer>
    <answer fraction="25" format="html"><text><![CDATA[<p>Jedno TCP spojení s více proudy (streams)</p>]]></text><feedback format="html"><text><![CDATA[<p>Správně.</p>]]></text></feedback></answer>
