  <question type="multichoice"><name><text>P12-19 HTTP/2 vlastnosti</text></name>
    <questiontext format="html"><text><![CDATA[<p>Co platí o <strong>HTTP/2</strong>? (Vyberte všechny správné.)</p>]]></text></questiontext>
    <generalfeedback format="html"><text><![CDATA[<p>HTTP/2: binární přenos v rámcích, jedno TCP spojení s proudy, komprimované hlavičky, server push, předpokládá TLS.</p>]]></text></generalfeedback>
    <defaultgrade>1</defaultgrade><penalty>0.3333333</penalty><hidden>0</hidden><single>false</single><shuffleanswers>true</shuffleanswers><answernumbering>abc</answernumbering>
