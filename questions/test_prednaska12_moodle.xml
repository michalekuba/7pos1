    <answer fraction="100" format="html"><text><![CDATA[<p>POP stáhne a smaže ze schránky; IMAP umožňuje vzdálenou práci se schránkami</p>]]></text><feedback format="html"><text><![CDATA[<p>Správně!</p>]]></text></feedback></answer>
