    <questiontext format="html"><text><![CDATA[<p>Co platí o <strong>IPsec</strong> v IPv6? (Vyberte všechny správné.)</p>]]></text></questiontext>
    <generalfeedback format="html"><text><![CDATA[<p>IPsec: AH (autentizace, ochrana před změnou), ESP (šifrování, preferovaná), databáze bezpečnostní politiky.</p>]]></text></generalfeedback>
    <defaultgrade>1</defaultgrade><penalty>0.3333333</penalty><hidden>0</hidden>
    <single>false</single><shuffleanswers>true</shuffleanswers><answernumbering>abc</answernumbering>
    <correctfeedback format="html"><text><![CDATA[<p>Správně!</p>]]></text></correctfeedback><partiallycorrectfeedback format="html"><text><![CDATA[<p>Částečně správně.</p>]]></text></partiallycorrectfeedback><incorrectfeedback format="html"><text><![CDATA[<p>Nesprávně.</p>]]></text></incorrectfeedback><shownumcorrect/>
    <answer fraction="33.33333" format="html"><text><![CDATA[<p>AH (Authentication Header) – ověření odesilatele a ochrana před změnou</p>]]></text><feedback format="html"><text><![CDATA[<p>Správně.</p>]]></text></feedback></answer>
    <answer fraction="33.33333" format="html"><text><![CDATA[<p>ESP (Encapsulating Security Payload) – šifrování, preferovaná</p>]]></text><feedback format="html"><text><![CDATA[<p>Správně.</p>]]></text></feedback></answer>
