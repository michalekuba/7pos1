    </answer>
    <answer fraction="0" format="html">
      <text><![CDATA[<p>Vyžaduje centrální vysílač</p>]]></text>
      <feedback format="html"><text><![CDATA[<p>Nesprávně. Centrální vysílač patří k jiné topologii.</p>]]></text></feedback>
    </answer>
  </question>

