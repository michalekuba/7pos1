  <!-- Q10: Esej – Princip optického vlákna -->
  <question type="essay">
    <name><text>P03-10 Princip optického vlákna (esej)</text></name>
    <questiontext format="html"><text><![CDATA[<p>Vysvětlete <strong>princip fungování optického vlákna</strong>. Popište, na jakém fyzikálním jevu je založeno, jakou má strukturu a jaké jsou jeho hlavní výhody oproti metalickým kabelům.</p>
<p><em>(Očekávaná délka: 5–10 vět.)</em></p>]]></text></questiontext>
    <generalfeedback format="html"><text><![CDATA[<p><strong>Vzorová odpověď:</strong> Optické vlákno je založeno na totálním odrazu světla. Má dvě vrstvy – jádro a plášť – s vhodnými indexy lomu, takže se světlo udrží uvnitř jádra. Výhody: obrovská šířka pásma (terabity), nevyzařuje a není rušeno, vhodné pro venkovní spoje. Nevýhody: dražší, méně pružné, dvoubodový spoj.</p>]]></text></generalfeedback>
    <defaultgrade>2</defaultgrade><penalty>0</penalty><hidden>0</hidden>
    <responseformat>editor</responseformat><responserequired>1</responserequired><responsefieldlines>10</responsefieldlines>
    <minwordlimit>30</minwordlimit><maxwordlimit>300</maxwordlimit>
    <attachments>0</attachments><attachmentsrequired>0</attachmentsrequired>
    <graderinfo format="html"><text><![CDATA[<ul><li>Fyzikální princip – totální odraz / lom světla (0,5 b)</li><li>Struktura – jádro a plášť, indexy lomu (0,5 b)</li><li>Výhody oproti metalickým kabelům (0,5 b)</li><li>Nevýhody (0,5 b)</li></ul>]]></text></graderinfo>
    <responsetemplate format="html"><text></text></responsetemplate>
  </question>

